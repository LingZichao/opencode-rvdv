# OpenCode-RVDV 环境变量配置

# ===== LLM API 配置 =====
QWEN_API_KEY=your_qwen_api_key_here

# ===== 项目路径配置 =====
PROJECT_ROOT=/path/to/opencode-rvdv
C910_RTL_ROOT=/path/to/openc910/C910_RTL_FACTORY/gen_rtl

# ===== UCAPI 覆盖率服务 =====
UCAPI_SERVER_URL=http://localhost:5000
UCAPI_API_ENDPOINT=/api/v1/query

# ===== FORCE-RISCV 配置 =====
FORCE_RISCV_BIN=/home/c910/force-riscv/bin/friscv
FORCE_RISCV_CONFIG=/home/c910/force-riscv/config/riscv_rv64_c910.config

# ===== OpenCode Server 配置 =====
OPENCODE_PORT=4096
OPENCODE_HOSTNAME=0.0.0.0

# ===== 其他配置 =====
# 最大迭代次数
MAX_ITERATIONS=10
# 覆盖率目标
COVERAGE_TARGET=95
