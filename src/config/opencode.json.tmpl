{
  "$schema": "https://opencode.ai/config.json",
  
  "server": {
    "port": {{OPENCODE_PORT}},
    "hostname": "{{OPENCODE_HOSTNAME}}",
    "mdns": true,
    "mdnsDomain": "rvdv.local"
  },
  
  "agent": {
    "coordinator": {
      "description": "主协调Agent - 规划RISC-V验证迭代流程",
      "mode": "primary",
      "prompt": "{file:.opencode/prompts/coordinator.md}",
      "color": "primary",
      "permission": {
        "task": {
          "coverage_collector": "allow",
          "generator": "allow",
          "recognizer": "allow"
        }
      }
    },
    
    "coverage_collector": {
      "description": "覆盖率收集子代理 - 获取、查询并整理覆盖率报告",
      "mode": "subagent",
      "prompt": "{file:.opencode/prompts/coverage_collector.md}",
      "tools": {
        "coverage_query": true,
        "coverage_fetch": true,
        "coverage_list": true,
        "read": true,
        "grep": true,
        "glob": true
      }
    },
    
    "generator": {
      "description": "ISG脚本生成子代理 - 生成FORCE-RISCV测试脚本",
      "mode": "subagent",
      "prompt": "{file:.opencode/prompts/generator.md}",
      "tools": {
        "write": true,
        "edit": true,
        "isg_compile": true,
        "isg_run": true,
        "knowledge-base": true,
        "read": true
      }
    },
    
    "recognizer": {
      "description": "微架构场景识别子代理 - 识别RTL模块行为",
      "mode": "subagent",
      "prompt": "{file:.opencode/prompts/recognizer.md}",
      "tools": {
        "read": true,
        "grep": true,
        "glob": true,
        "browse": true,
        "knowledge-base": true
      }
    }
  },
  
  "command": {
    "verify": {
      "description": "启动RTL覆盖率验证任务",
      "template": "分析RTL文件 $1 行号范围 $2 的覆盖率不足问题并制定ISG脚本方案",
      "agent": "coordinator"
    },
    "collect": {
      "description": "仅收集/查询覆盖率（不生成脚本）",
      "template": "收集并查询RTL文件 $1 行号范围 $2 的覆盖率情况",
      "agent": "coverage_collector",
      "subtask": true
    },
    "generate": {
      "description": "仅生成ISG脚本（不执行仿真）",
      "template": "根据以下测试计划生成ISG脚本: $ARGUMENTS",
      "agent": "generator",
      "subtask": true
    },
    "status": {
      "description": "查看任务状态和覆盖率进度",
      "template": "查看当前任务的进度和覆盖率状态",
      "agent": "coordinator"
    }
  },
  
  "instructions": [
    "workspace/agentDoc/C910ISA_Agent_Friendly.md",
    "workspace/agentDoc/condition_coverage.md"
  ],
  
  "permission": {
    "edit": "allow",
    "bash": "allow"
  },
  
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  
  "experimental": {
    "lsp": true
  }
}
