{
  "$schema": "https://opencode.ai/config.json",

  "server": {
    "port": {{OPENCODE_PORT}},
    "hostname": "{{OPENCODE_HOSTNAME}}",
    "mdns": true,
    "mdnsDomain": "rvdv.local"
  },

  "model": "deepseek/deepseek-v4-pro",
  "small_model": "deepseek/deepseek-v4-flash",

  "agent": {
    "coordinator": {
      "description": "主协调Agent - 规划RISC-V验证迭代流程",
      "mode": "primary",
      "model": "deepseek/deepseek-v4-pro",
      "prompt": "{file:.opencode/prompts/coordinator.md}",
      "color": "primary",
      "tools": {
        "read": true,
        "grep": true,
        "glob": true,
        "skill": true,
        "edit": false,
        "write": false,
        "bash": false,
        "apply_patch": false
      },
      "permission": {
        "skill": {
          "*": "deny",
          "coverage": "allow"
        },
        "task": {
          "collector": "allow",
          "explore": "allow",
          "generator": "allow",
          "instracer": "allow"
        }
      }
    },

    "explore": {
      "description": "内置只读探索子代理 - 快速检索和分析代码库上下文",
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-flash"
    },

    "collector": {
      "description": "覆盖率收集子代理 - 获取、查询并整理覆盖率报告",
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-flash",
      "prompt": "{file:.opencode/prompts/collector.md}",
      "tools": {
        "read": true,
        "grep": true,
        "glob": true,
        "skill": true,
        "edit": false,
        "write": false,
        "bash": true,
        "apply_patch": false
      },
      "permission": {
        "skill": {
          "*": "deny",
          "coverage": "allow"
        },
        "bash": {
          "*": "deny",
          "python3 scripts/ucapi_client.py *": "allow",
          "python3 scripts/simulation_runner.py *": "allow"
        },
        "edit": "deny"
      }
    },

    "generator": {
      "description": "ISG脚本生成子代理 - 生成FORCE-RISCV测试脚本",
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-flash",
      "prompt": "{file:.opencode/prompts/generator.md}",
      "tools": {
        "read": true,
        "grep": true,
        "glob": true,
        "skill": true,
        "edit": true,
        "write": true,
        "bash": true,
        "apply_patch": false
      },
      "permission": {
        "skill": {
          "*": "deny",
          "isg-compile": "allow",
          "gem5-prescreen": "allow"
        },
        "bash": {
          "*": "deny",
          "python3 scripts/isg_compiler.py *": "allow",
          "python3 scripts/gem5_prescreener.py run *": "allow"
        },
        "edit": "allow"
      }
    },

    "instracer": {
      "description": "指令运行轨迹采样子代理 - 编写APV YAML并从FSDB收集指令运行数据",
      "mode": "subagent",
      "model": "deepseek/deepseek-v4-pro",
      "prompt": "{file:.opencode/prompts/instracer.md}",
      "tools": {
        "read": true,
        "grep": true,
        "glob": true,
        "skill": true,
        "edit": true,
        "write": true,
        "bash": true,
        "apply_patch": false
      },
      "permission": {
        "skill": {
          "*": "deny",
          "fsdb-sampling": "allow"
        },
        "bash": {
          "*": "deny",
          "python3 .opencode/skills/fsdb-sampling/AgenticPipeViewer/view.py *": "allow"
        },
        "edit": "allow"
      }
    }
  },

  "command": {
    "verify": {
      "description": "启动RTL覆盖率验证任务",
      "template": "分析RTL文件 $1 行号范围 $2 的覆盖率不足问题并制定ISG脚本方案",
      "agent": "coordinator"
    },
    "collect": {
      "description": "仅收集/查询覆盖率（不生成脚本）",
      "template": "收集并查询RTL文件 $1 行号范围 $2 的覆盖率情况",
      "agent": "collector",
      "subtask": true
    },
    "generate": {
      "description": "生成ISG脚本并完成gem5预筛选（不执行RTL仿真）",
      "template": "根据以下测试计划生成ISG脚本并完成gem5预筛选，不执行RTL/VCS仿真: $ARGUMENTS",
      "agent": "generator",
      "subtask": true
    },
    "trace": {
      "description": "编写APV采样脚本并从FSDB收集指令运行数据",
      "template": "根据以下FSDB采样需求编写APV YAML并收集指令运行数据。参数应包含FSDB路径、globalClock、scope、目标事件/指令、identity anchors以及可选输出路径: $ARGUMENTS",
      "agent": "instracer",
      "subtask": true
    },
    "status": {
      "description": "查看任务状态和覆盖率进度",
      "template": "查看当前任务的进度和覆盖率状态",
      "agent": "coordinator"
    }
  },

  "permission": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "skill": {
      "*": "ask"
    },
    "bash": {
      "*": "ask"
    },
    "edit": "ask"
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },

  "experimental": {
    "lsp": true
  }
}
